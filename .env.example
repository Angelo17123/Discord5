# ============================================
# DISCORD SELFBOT - CONFIGURACIÓN SEGURA
# ============================================
# ⚠️ NUNCA compartas tu token con NADIE

# Token de Discord (OBLIGATORIO)
DISCORD_TOKEN=tu_token_aqui

# Canal base de voz (OBLIGATORIO)
BASE_CHANNEL_ID=1374565606967214100

# ============================================
# CONFIGURACIÓN DE SEGURIDAD
# ============================================

# Prefijo para comandos - USA ALGO ÚNICO que no sea común
# Evita: !, !, ?, $, .  (demasiado comunes)
# Recomendado: algo raro como ,, o ;; o ~~ 
COMMAND_PREFIX=,,

# Modo debug (SOLO activar si hay problemas)
DEBUG_MODE=false

# Nivel de log (production = info, debugging = debug)
LOG_LEVEL=info

# ============================================
# INTERVALOS DE SEGURIDAD
# ============================================

# Intervalo de watchdog (mínimo 60000ms = 1 minuto)
# ⚠️ Valores bajos = más tráfico = más detectable
WATCHDOG_INTERVAL=120000

# Delay de reconexión base (mínimo 5000ms)
# Se multiplica con backoff exponencial automáticamente
RECONNECT_DELAY=8000

# ============================================
# FUNCIONES OPCIONALES (TODAS DESACTIVADAS POR DEFECTO)
# ============================================

# Auto-responder DMs (CUIDADO: puede ser detectado)
AUTO_RESPONDER_ENABLED=false
AUTO_RESPONDER_MESSAGE=Hey, no estoy disponible ahora. Te respondo luego!

# Monitoreo de raids (SOLO MONITOREO, no kickea)
RAID_PROTECTION_ENABLED=false
RAID_PROTECTION_JOIN_LIMIT=10
RAID_PROTECTION_TIME_WINDOW=10000

# Anti-crash
ANTI_CRASH_ENABLED=true

# ============================================
# DASHBOARD (OPCIONAL - Recomendado desactivar)
# ============================================

# ⚠️ El dashboard expone información - desactivar si no es necesario
DASHBOARD_ENABLED=false
DASHBOARD_PORT=3000
DASHBOARD_PASSWORD=CambiaEstaContraseña123!

# ============================================
# NOTIFICACIONES (OPCIONALES)
# ============================================

WEBHOOK_URL=
MENTION_ALERTS=false
DM_ALERTS=false
