{
  "name": "discord-selfbot-pro",
  "version": "2.0.0",
  "description": "Selfbot profesional de Discord con arquitectura modular y funciones avanzadas",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "watch": "tsc -w",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:logs": "pm2 logs discord-selfbot",
    "dashboard": "node dashboard/server.js",
    "lint": "eslint src/**/*.ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "discord",
    "selfbot",
    "automation",
    "voice",
    "moderation"
  ],
  "author": "Pro Developer",
  "license": "MIT",
  "dependencies": {
    "discord.js-selfbot-v13": "^3.1.4",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "dotenv": "^16.3.1",
    "chalk": "^4.1.2",
    "moment": "^2.29.4",
    "axios": "^1.6.2",
    "express": "^4.18.2",
    "socket.io": "^4.7.4",
    "node-cron": "^3.0.3",
    "fs-extra": "^11.2.0",
    "lodash": "^4.17.21",
    "ms": "^2.1.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "@types/express": "^4.17.21",
    "@types/node-cron": "^3.0.11",
    "@types/fs-extra": "^11.0.4",
    "@types/lodash": "^4.14.202",
    "@types/ms": "^0.7.34",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.16.0",
    "@typescript-eslint/parser": "^6.16.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
